---
const steps = [
	{
		title: 'Read fast',
		body: 'Use native static search and crisp sectioning so builders can jump straight into setup, architecture, or APIs.',
	},
	{
		title: 'Explain clearly',
		body: 'Keep Mermaid for core diagrams, then add Astro components where motion or visual emphasis improves comprehension.',
	},
	{
		title: 'Scale cleanly',
		body: 'Encapsulate patterns as components rather than accumulating one-off CSS and JavaScript behavior.',
	},
];
---

<aside class="calimero-panel">
	<p class="calimero-pill">Migration Shape</p>
	<div class="calimero-flow" style="margin-top: 1rem;">
		{
			steps.map((step, index) => (
				<div class="calimero-flow-step" data-step={index + 1}>
					<strong>{step.title}</strong>
					<p style="margin: 0.35rem 0 0;">{step.body}</p>
				</div>
			))
		}
	</div>
</aside>
