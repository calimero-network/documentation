---
const metrics = [
	{ value: 'Static Search', label: 'Pagefind ships with the site and needs no external service.' },
	{ value: 'Mermaid Ready', label: 'Existing architecture diagrams can move over with minimal rewriting.' },
	{ value: 'MDX + Astro', label: 'Animations and richer visuals can be page-scoped instead of global hacks.' },
];
---

<div class="calimero-panel">
	<p class="calimero-pill">POC Snapshot</p>
	<h2 style="margin-top: 1rem;">Docs that feel like a product surface</h2>
	<p>
		This prototype keeps the static-site deployment model while making room for richer landing pages,
		component-driven callouts, and stronger visual hierarchy.
	</p>
	<div class="calimero-kpis">
		{
			metrics.map((metric) => (
				<div class="calimero-kpi">
					<strong>{metric.value}</strong>
					<span>{metric.label}</span>
				</div>
			))
		}
	</div>
</div>
