---
---

<div class="hero">
  <div class="hero-glow" aria-hidden="true"></div>

  <div class="hero-body">
    <span class="hero-badge">
      <span class="hero-badge-dot"></span>
      Developer Docs
    </span>

    <h1 class="hero-title">
      Build private apps.<br />
      <span class="hero-accent">Stay in control.</span>
    </h1>

    <p class="hero-desc">
      Calimero is a privacy-first execution layer. Isolated contexts, sovereign identity,
      and controlled data sharing — built for developers who can't afford to compromise.
    </p>

    <div class="hero-actions">
      <a href="/guides/example" class="btn-primary">
        Quick start
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="https://github.com/calimero-network" class="btn-ghost" target="_blank" rel="noopener">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>
        GitHub
      </a>
    </div>
  </div>
</div>

<style>
  .hero {
    position: relative;
    margin: -2rem calc(-1 * var(--sl-content-pad-x, 1.5rem)) 2rem;
    padding: 3rem var(--sl-content-pad-x, 1.5rem) 2.5rem;
    border-bottom: 1px solid #27272a;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 55% 80% at 30% -10%, rgba(165, 255, 17, 0.07), transparent 60%);
    pointer-events: none;
    animation: glow-shift 8s ease-in-out infinite alternate;
  }

  @keyframes glow-shift {
    from { opacity: 0.7; }
    to   { opacity: 1; }
  }

  .hero-body {
    position: relative;
    z-index: 1;
    max-width: 36rem;
    animation: fade-up 0.4s ease both;
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: rgba(165, 255, 17, 0.07);
    border: 1px solid rgba(165, 255, 17, 0.2);
    color: #b8ff44;
    margin-bottom: 1.1rem;
  }

  .hero-badge-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #a5ff11;
    animation: dot-pulse 2.5s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%, 100% { box-shadow: 0 0 0 2px rgba(165, 255, 17, 0.2); }
    50%       { box-shadow: 0 0 0 4px rgba(165, 255, 17, 0.07); }
  }

  /* Title */
  .hero-title {
    font-size: clamp(1.6rem, 4vw, 2.25rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.04em;
    color: #fafafa;
    margin: 0 0 0.85rem;
  }

  .hero-accent {
    background: linear-gradient(120deg, #a5ff11, #d4ff6e, #a5ff11);
    background-size: 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 4s linear infinite;
  }

  @keyframes shimmer {
    from { background-position: 0%; }
    to   { background-position: 200%; }
  }

  /* Description */
  .hero-desc {
    font-size: 0.9rem;
    line-height: 1.65;
    color: #71717a;
    margin: 0 0 1.5rem;
    max-width: 32rem;
  }

  /* Actions */
  .hero-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .btn-primary,
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0.85rem;
    border-radius: 6px;
    font-size: 0.8125rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.12s ease;
    white-space: nowrap;
  }

  /* Lime bg → DARK text for proper contrast */
  .btn-primary {
    background: #a5ff11;
    color: #09090b !important;
    border: 1px solid #a5ff11;
  }
  .btn-primary:hover {
    background: #baff35;
    border-color: #baff35;
    color: #09090b !important;
    text-decoration: none;
    transform: translateY(-1px);
  }

  .btn-ghost {
    background: transparent;
    color: #a1a1aa;
    border: 1px solid #27272a;
  }
  .btn-ghost:hover {
    border-color: #3f3f46;
    color: #e4e4e7;
    text-decoration: none;
  }

  @media (max-width: 600px) {
    .hero { padding-top: 2rem; padding-bottom: 1.75rem; }
    .hero-title { font-size: 1.5rem; }
  }
</style>
